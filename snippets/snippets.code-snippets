  "React Router Client Loader": {
    "prefix": "rrcl",
    "body": [
      "import type { Route } from \"./+types/${TM_FILENAME_BASE}\";",
      "",
      "export async function clientLoader({ serverLoader }: Route.ClientLoaderArgs) {",
      "\t// call the server loader",
      "\tconst serverData = await serverLoader();",
      "\t// And/or fetch data on the client",
