  "React Router Error Boundary": {
    "prefix": "rreb",
    "body": [
      "import { isRouteErrorResponse, useRouteError } from \"react-router\";",
      "",
      "export function ErrorBoundary() {",
      "\tconst error = useRouteError();",
      "",
      "\tif (isRouteErrorResponse(error)) {",
      "\t\treturn (",
      "\t\t\t<div>",
      "\t\t\t\t<h1>",
      "\t\t\t\t\t{error.status} {error.statusText}",
      "\t\t\t\t</h1>",
      "\t\t\t\t<p>{error.data}</p>",
      "\t\t\t</div>",
      "\t\t);",
      "\t} else if (error instanceof Error) {",
      "\t\treturn (",
      "\t\t\t<div>",
      "\t\t\t\t<h1>Error</h1>",
      "\t\t\t\t<p>{error.message}</p>",
      "\t\t\t\t<p>The stack trace is:</p>",
      "\t\t\t\t<pre>{error.stack}</pre>",
      "\t\t\t</div>",
      "\t\t);",
      "\t} else {",
      "\t\treturn <h1>Unknown Error</h1>;",
      "\t}",
      "}"
    ],
    "description": "When other route module APIs throw, the route module ErrorBoundary will render instead of the route component."
  },
