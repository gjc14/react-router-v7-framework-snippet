  "React Router Middleware": {
    "prefix": "rrmw",
    "body": [
      "import type { Route } from \"./+types/${TM_FILENAME_BASE}\";",
      "",
      "const loggingMiddleware: Route.MiddlewareFunction = async ({ request, context }, next) => {",
      "\tconsole.log(`\\${new Date().toISOString()} \\${request.method} \\${request.url}`);",
      "\tconst start = performance.now();",
      "\tconst response = await next();",
      "\tconst duration = performance.now() - start;",
      "\tconsole.log(`\\${new Date().toISOString()} Response \\${response.status} (\\${duration}ms)`);",
      "\treturn response;",
      "}",
      "",
      "export const middleware = [loggingMiddleware];"
    ],
    "description": "Route middleware runs sequentially on the server before and after document and data requests."
  },
